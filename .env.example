# Optional: Groq API key for AI coaching notes (preferred).
# App still works without this key using rule-based recommendations only.
REACT_APP_GROQ_API_KEY=

# Optional: override Groq base URL and model
REACT_APP_GROQ_BASE_URL=https://api.groq.com/openai/v1
REACT_APP_GROQ_MODEL=llama-3.1-8b-instant

# Optional fallback provider if Grok key is not set
REACT_APP_GEMINI_API_KEY=
